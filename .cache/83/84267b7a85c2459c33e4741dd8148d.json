,"generated":{"line":71,"column":43}}],"sources":{"spriteDecomposer.ts":"\r\n    interface frameHash {\r\n        frame:{\r\n            x: number;\r\n            y: number;\r\n            w: number;\r\n            h: number;\r\n        };\r\n        rotated: boolean;\r\n        trimmed: boolean;\r\n        spriteSourceSize: {\r\n            x: number;\r\n            y: number;\r\n            w: number;\r\n            h: number;\r\n        };\r\n        sourceSize:{\r\n            w: number;\r\n            h: number;\r\n        };\r\n    }\r\n\r\n    interface outerHash {\r\n        frames: {[name: string]: frameHash}\r\n        meta: {\r\n            app: string;\r\n            version: string;\r\n            image: string;\r\n            format: string;\r\n            size: {w: number, h: number};\r\n            scale: string;\r\n            smartupdate?: string;\r\n        };\r\n         \r\n    }\r\n\r\n    const spriteDecomposer = (img: string, width: number, height: number, rows: number, cols: number) => {\r\n        //TODO: Get width and height of spriteSheet.\r\n        //TODO: Get number of frames.\r\n        //TODO: Divide width and height by numFrames to get x and y increments.\r\n        //TODO: Incremenet across sheet via x and y increments.\r\n        //TODO: Generate an object for each of these frames and add to object array.\r\n        //TODO: Generate json file from array of objects.\r\n\r\n        let x = 1;\r\n        let y = 1;\r\n        let w = width;\r\n        let h = height;\r\n        let image = img;\r\n        let xInc = width/cols;\r\n        let yInc = height/rows;\r\n        let framesArray = []\r\n        \r\n\r\n        const hash: outerHash = {\r\n            frames: {},\r\n            meta: {\r\n                app: \"Sprite-Decomposer\",\r\n                version: \"1.0\",\r\n                image: image,\r\n                format: \"RGBA8888\",\r\n                size: {w: width, h: height},\r\n                scale: \"1\"\r\n            }\r\n        };\r\n\r\n        for(let i = 0; i < rows; i++){\r\n            for(let k = 0; k < cols; k++){\r\n                let frameName = \"frame-\" + i + \"-\" + k + \".png\"\r\n                hash.frames[frameName] = {\r\n                    frame: {x, y, h, w},\r\n                    rotated: false,\r\n                    trimmed: false,\r\n                    spriteSourceSize: {x, y, w, h},\r\n                    sourceSize: {\r\n                        w: width,\r\n                        h: height,\r\n                    },\r\n                };\r\n                x += xInc;\r\n            }\r\n            x = 1;\r\n            y += yInc;\r\n        }\r\n\r\n        \r\n        return JSON.stringify(hash)\r\n\r\n    }\r\n\r\nexport {spriteDecomposer}\r\n\r\n"},"lineCount":null}},"error":null,"hash":"d1a2a736d75bca229adcd2f2d0a75cd6","cacheData":{"env":{}}}